{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "linter": {
        "rules": {
            "performance": {
                "noBarrelFile": "off"
            }
        }
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**",
            "!**/.next",
            "!**/dist",
            "!**/.turbo",
            "!**/dev-dist",
            "!**/.zed",
            "!**/.vscode",
            "!**/routeTree.gen.ts",
            "!**/src-tauri",
            "!**/.nuxt",
            "!bts.jsonc",
            "!**/.expo",
            "!**/.wrangler",
            "!**/.alchemy",
            "!**/.svelte-kit",
            "!**/wrangler.jsonc",
            "!**/.source"
        ]
    },
    "extends": [
        "ultracite/core",
        "ultracite/next"
    ]
}
